# URL of the deployed Vercel AI SDK chatbot whose /api/chat endpoint accepts
# the x-eval-run-id / x-eval-case-id headers.
CHATBOT_URL=https://chatbot-delta-rosy.vercel.app

# Optional. Defaults to run-<timestamp>.
# EVAL_RUN_ID=run-demo-1

# Bronto credentials.
BRONTO_API_KEY=
BRONTO_REGION=eu

# Where Phase 2 looks for completed chat requests.
# - "traces" (default, recommended): query the Vercel Traces drain dataset for
#   ai.streamText spans with typed $ai.* attributes. Requires the chatbot to
#   have experimental_telemetry enabled on streamText and a Vercel Traces drain
#   configured to Bronto.
# - "logs": fall back to the Vercel Logs drain dataset and match @raw LIKE.
#   Works without OTel but is slower and brittle.
BRONTO_SOURCE=traces

# Traces drain target. Defaults match Vercel's standard service-name dataset.
BRONTO_TRACES_DATASET=vercel-ai-demo
BRONTO_TRACES_COLLECTION=.traces

# Logs drain target. Only used when BRONTO_SOURCE=logs, or as a fallback
# destination for the eval score ingestion (writes always go here).
BRONTO_COLLECTION=vercel
BRONTO_DATASET=chatbot

# Anthropic API key for the LLM judge. claude-sonnet-4-20250514 has a 5 req/min
# rate limit on default tier; the scoring script paces itself to stay under.
ANTHROPIC_API_KEY=
