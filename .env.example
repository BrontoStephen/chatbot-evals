# URL of the deployed Vercel AI SDK chatbot whose /api/chat endpoint accepts
# the x-eval-run-id / x-eval-case-id headers.
CHATBOT_URL=https://chatbot-delta-rosy.vercel.app

# Optional. Defaults to run-<timestamp>.
# EVAL_RUN_ID=run-demo-1

# Bronto credentials and routing. The chatbot must be writing into the same
# (collection, dataset) you set here, via Vercel Log Drains.
BRONTO_API_KEY=
BRONTO_REGION=eu
BRONTO_COLLECTION=vercel
BRONTO_DATASET=chatbot

# Anthropic API key for the LLM judge. claude-sonnet-4-20250514 has a 5 req/min
# rate limit on default tier; the scoring script paces itself to stay under.
ANTHROPIC_API_KEY=
